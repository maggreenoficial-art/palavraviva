# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files / secrets
.env
.env.*
!.env.example
secrets/
**/credentials*.json

# analytics local data
server/data/

# áudio privado espelhado (usar npm run media:sync)
server/private-media/*
!server/private-media/.gitkeep
!server/private-media/README.md

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
