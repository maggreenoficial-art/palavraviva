WIVEN_TOOL_DIARIO_PRICE=29.9
WIVEN_TOOL_FOTO_JESUS_PRICE=5
# Kie.ai — GPT Image 2 (Foto com Jesus)
KIE_API_KEY=
# Opcional: segredo HMAC das gerações / tokens de áudio (padrão: WIVEN_WEBHOOK_SECRET)
