# Dias liberados após pagamento aprovado (trial do app = 72h, não 24h)
SUBSCRIPTION_DAYS=30
# Ative na credencial Wiven: Criar/Consultar Transações

# Streaming de áudio protegido (/api/media/*)
# TTL do token em segundos (padrão 180)
MEDIA_TOKEN_TTL_SEC=180
# Origens permitidas no stream (vírgula). Vazio = usa PAYMENTS_PUBLIC_URL + localhost
MEDIA_ALLOWED_ORIGINS=https://palavraviva-omega.vercel.app
# S3 / Cloudflare R2 (produção recomendada). Sem isso, usa assets/audio no servidor.
MEDIA_S3_BUCKET=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_ENDPOINT=
MEDIA_S3_REGION=auto
MEDIA_S3_PREFIX=audio

