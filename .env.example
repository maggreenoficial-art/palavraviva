EXPO_PUBLIC_PAYMENTS_URL=http://localhost:8788
PAYMENTS_PORT=8788
# Produção: HTTPS público do app (ex.: https://palavraviva-omega.vercel.app)
PAYMENTS_PUBLIC_URL=http://localhost:8788
WIVEN_PUBLIC_KEY=
WIVEN_SECRET_KEY=
WIVEN_WEBHOOK_SECRET=
