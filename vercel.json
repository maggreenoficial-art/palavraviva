{
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "framework": null,
  "functions": {
    "api/[[...slug]].js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ]
}
